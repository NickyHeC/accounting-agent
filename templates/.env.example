# Dedalus API Key (for LLM agent runner)
DEDALUS_API_KEY=your_dedalus_api_key_here

# Mercury API Token
MERCURY_TOKEN=your_mercury_api_token_here

# Ramp API Credentials (OAuth 2.0 client credentials)
RAMP_ID=your_ramp_client_id
RAMP_SEC=your_ramp_client_secret
RAMP_TOKEN=your_ramp_access_token

# MCP server slugs on Dedalus marketplace
MERCURY_MCP_SERVER=your-org/mercury-mcp
RAMP_MCP_SERVER=your-org/ramp-mcp
SEARCH_MCP_SERVER=your-org/brave-search-mcp

# LLM model
MODEL=anthropic/claude-sonnet-4-20250514

# Agent timeout in seconds
AGENT_TIMEOUT=1200
